# Per-repo path overrides
#
# Copy this file to `~/.claude/project-repos.local.env` and uncomment the
# lines for the repos you want to override. The installer sources this file
# after auto-discovery, so any values here take precedence.
#
# Variable names follow the pattern: PROJECT_REPO_<UPPER_SHORTNAME>
# Shortnames are defined in repos.conf.

# PROJECT_REPO_MOBILE=/custom/path/to/demo-mobile
# PROJECT_REPO_WEB=/custom/path/to/demo-web
# PROJECT_REPO_API=/custom/path/to/demo-api
# PROJECT_REPO_SERVER=/custom/path/to/demo-server
# PROJECT_REPO_INFRA=/custom/path/to/demo-infra
